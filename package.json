{
  "name": "humanize2",
  "version": "0.1.0",
  "description": "A local MCP server that routes prompts to external coding agents.",
  "type": "module",
  "bin": {
    "humanize2": "./dist/index.js",
    "humanize2-call": "./dist/dev-client.js",
    "humanize2-hub": "./dist/hub-server.js",
    "humanize2-rpc": "./dist/hub-client.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "dev:call": "tsx src/dev-client.ts",
    "hub": "tsx src/hub-server.ts",
    "hub:call": "tsx src/hub-client.ts",
    "smoke:btc": "tsx scripts/real-btc-smoke.ts",
    "smoke:nested-market": "npm run build && tsx scripts/nested-market-smoke.ts",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "parse5": "^8.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.17.2",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
